# Varaksha — environment variables
# Copy this to .env and fill in your values.
# Never commit .env to version control.

# ── Rust Gateway ──────────────────────────────────────────────────────────────
VARAKSHA_BIND=0.0.0.0:8080
AGENT01_URL=http://127.0.0.1:8001/v1/profile
# Static salt for IP hashing — change this in production, never reuse across deployments
VARAKSHA_IP_SALT=change-this-to-a-random-32-char-string-in-production

# ── Python Agents ─────────────────────────────────────────────────────────────
# Keys are printed to stdout on gateway startup. Copy them here.
GATEWAY_VERIFYING_KEY_HEX=<paste 64-char hex from gateway startup log>

# Each agent generates its own key pair on first run (printed to stdout).
# For production, generate once and store here.
AGENT01_SIGNING_KEY_HEX=
AGENT01_VERIFYING_KEY_HEX=
AGENT02_SIGNING_KEY_HEX=
AGENT02_VERIFYING_KEY_HEX=
AGENT03_SIGNING_KEY_HEX=

# ── Pipeline Orchestrator ────────────────────────────────────────────────────
PIPELINE_URL=http://127.0.0.1:8000/v1/orchestrate
AGENT02_URL=http://127.0.0.1:8002/v1/graph
AGENT03_URL=http://127.0.0.1:8003/v1/decide

# ── LLM Narrative (Agent 03) ─────────────────────────────────────────────────
# Leave blank to use template narratives (no LLM call, full offline operation)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ── Models ────────────────────────────────────────────────────────────────────
MODEL_PATH=data/models/isolation_forest.pkl
INJECTION_INDEX_PATH=data/models/injection_index.faiss
INJECTION_STRINGS_PATH=data/models/injection_strings.json
LEGIT_CORPUS_PATH=data/models/legit_memo_corpus.json

# ── Demo ─────────────────────────────────────────────────────────────────────
GATEWAY_URL=http://127.0.0.1:8080/v1/tx
