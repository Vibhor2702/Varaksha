# ── Varaksha Risk-Cache Gateway — Environment Variables ──────────────────────
# Copy this file to .env for local development.
# In Railway: set these in the service Variables tab.

# ── Authentication (required in production) ───────────────────────────────────
VARAKSHA_API_KEY=changeme-generate-with-openssl-rand-hex-32
VARAKSHA_UPDATE_SECRET=changeme-generate-with-openssl-rand-hex-32
VARAKSHA_GRAPH_SECRET=changeme-generate-with-openssl-rand-hex-32

# ── Deployment tier ───────────────────────────────────────────────────────────
# cloud   → enables /update_cache and /graph_update, cache TTL 180s
# on_prem → same + higher rate limits, cache TTL 300s
# edge    → disables graph agent routes, no IsolationForest, cache TTL 60s
VARAKSHA_TIER=cloud

# ── Production mode (strict secret enforcement) ───────────────────────────────
# Set to true in Railway; leave false for local dev
VARAKSHA_PRODUCTION=false

# ── Model paths ───────────────────────────────────────────────────────────────
VARAKSHA_MODELS_DIR=../models

# ── ONNX Runtime (required at runtime when using load-dynamic feature) ────────
# Point to libonnxruntime.so — auto-set in Docker image
# On local Linux/Mac: set to your ort dylib path
# On Windows dev: the start_dev.sh script auto-detects from .venv
# ORT_DYLIB_PATH=/usr/local/lib/libonnxruntime.so

# ── Server binding ────────────────────────────────────────────────────────────
VARAKSHA_BIND_ADDR=127.0.0.1:8080

# ── Audit logging ─────────────────────────────────────────────────────────────
VARAKSHA_AUDIT_LOG_PATH=./logs/security_audit.jsonl

# ── Rate limiting ─────────────────────────────────────────────────────────────
# VARAKSHA_RATE_MAX=100         # requests per window per device (default: tier)
# VARAKSHA_RATE_WINDOW_S=60     # window size in seconds

# ── Cache TTL override ────────────────────────────────────────────────────────
# VARAKSHA_CACHE_TTL_S=180      # seconds (default: tier)

# ── ONNX Runtime tuning ───────────────────────────────────────────────────────
# VARAKSHA_ORT_INTRA_THREADS=4
# VARAKSHA_ORT_INTER_THREADS=2
# VARAKSHA_ORT_OPT_LEVEL=level1  # disable | level1 | level2 | all

# ── Logging ───────────────────────────────────────────────────────────────────
RUST_LOG=info
